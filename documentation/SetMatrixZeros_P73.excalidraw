    {
      "id": "JloIJfSZnlz8gUKmwYSIr",
      "type": "text",
      "x": 380.5448155236415,
      "y": -3398.230274787827,
      "width": 1668.8958740234375,
      "height": 245,
      "angle": 0,
      "strokeColor": "#181604",
      "backgroundColor": "#181604",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b2E",
      "roundness": null,
      "seed": 1398025797,
      "version": 729,
      "versionNonce": 757735781,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784231453839,
      "link": null,
      "locked": false,
      "text": "i found another way that kept the time same as O(m+n) but reduced the space required from O(m+n) to O(n)\n\nbasically we keep an array for the columns only and keep a flag rowHasZero we scan row by row\nwe scan a row and store all j values where the 0 has occured in our array. and if the row had a zero we immediately make\nthe row all zeros and reset our rowHasZero flag and then move to the next row.\nafter all rows are completed we make all the columns zero according to our array for columns.\nsince there are n columns our space complexity is reduced from my original solution to just O(n)",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "i found another way that kept the time same as O(m+n) but reduced the space required from O(m+n) to O(n)\n\nbasically we keep an array for the columns only and keep a flag rowHasZero we scan row by row\nwe scan a row and store all j values where the 0 has occured in our array. and if the row had a zero we immediately make\nthe row all zeros and reset our rowHasZero flag and then move to the next row.\nafter all rows are completed we make all the columns zero according to our array for columns.\nsince there are n columns our space complexity is reduced from my original solution to just O(n)",
      "autoResize": true,
      "lineHeight": 1.25
    },
