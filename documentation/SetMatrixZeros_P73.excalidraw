    {
      "id": "5xHlazr49wJ7-VOPBpfcS",
      "type": "text",
      "x": 389.56552446904925,
      "y": -3851.6309932712284,
      "width": 1211.3541259765625,
      "height": 350,
      "angle": 0,
      "strokeColor": "#181604",
      "backgroundColor": "#181604",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b2C",
      "roundness": null,
      "seed": 1463108613,
      "version": 619,
      "versionNonce": 882160933,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784219006833,
      "link": null,
      "locked": false,
      "text": "I can think of only 1 way to solve the problem \n\nstore which rows are zero and non zero in an array\nstore which columns are zero and non zero in an array\nbased on the index of those array index corresponding to the row number that\nis zero we iterate over the row to set all its elements to zero.\nsimilarly we iterate over the rows and set the index that corresponds to the column\nthat is supposed to be zero and set all those elemts to zero for each row to make the\ncolumns zero.\nwe have successfully mutated the given matrix to its required form.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "I can think of only 1 way to solve the problem \n\nstore which rows are zero and non zero in an array\nstore which columns are zero and non zero in an array\nbased on the index of those array index corresponding to the row number that\nis zero we iterate over the row to set all its elements to zero.\nsimilarly we iterate over the rows and set the index that corresponds to the column\nthat is supposed to be zero and set all those elemts to zero for each row to make the\ncolumns zero.\nwe have successfully mutated the given matrix to its required form.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xFt0Ee6FzHcM4Ki8T_HyK",
      "type": "rectangle",
      "x": 372.41879108941134,
      "y": -3780.086724859674,
      "width": 1263.108154771641,
      "height": 314.4140278021523,
      "angle": 0,
      "strokeColor": "#181604",
