    {
      "id": "_J40Z1WmuSybkLYnFsNkm",
      "type": "text",
      "x": 5007.088127617195,
      "y": -3635.7823321200012,
      "width": 19738.353515625,
      "height": 620,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
