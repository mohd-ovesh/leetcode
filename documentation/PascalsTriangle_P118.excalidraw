    {
      "id": "xbwyrM0hNZqiEXdfr5qC6",
      "type": "text",
      "x": 370.68704812108297,
      "y": -3065.8341907967424,
      "width": 2094.3125,
      "height": 315,
      "angle": 0,
      "strokeColor": "#181604",
      "backgroundColor": "#181604",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "b2H",
      "roundness": null,
      "seed": 304259813,
      "version": 1446,
      "versionNonce": 710568741,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "jww0im4xUca_zJfeMqEoi",
          "type": "arrow"
        }
      ],
      "updated": 1784235489532,
      "link": null,
      "locked": false,
      "text": "i got to know that the most optimal solution uses just O(1) space that is no extra space at all just 2 variables\n\nWe are doing similar thing as i did with my first approach except that instead of using two array for storing the info of which columns are zero\nwe are just using the first row to keep track of all zero columns and first column to keep track of all zero rows. we go over the matrix\nfrom the (1,1) indexed element instead of the usual (0,0) starting and if a row has zero we make the first column of that row which is part of the \nrow tracking column as zero. and also make the corresponding column of the first row zero too. after that we do another pass going over the first row\nand making all columns zero. and we do another passing going over the first column and making all rows zero.\nat last we use our 2 variables that indicate if our first row or first column had a zero and change those suitably by making them all zero as well.\nhence our problem gets solved. nice i didn't think of that i would remember this pattern of solving for later reference as well.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "i got to know that the most optimal solution uses just O(1) space that is no extra space at all just 2 variables\n\nWe are doing similar thing as i did with my first approach except that instead of using two array for storing the info of which columns are zero\nwe are just using the first row to keep track of all zero columns and first column to keep track of all zero rows. we go over the matrix\nfrom the (1,1) indexed element instead of the usual (0,0) starting and if a row has zero we make the first column of that row which is part of the \nrow tracking column as zero. and also make the corresponding column of the first row zero too. after that we do another pass going over the first row\nand making all columns zero. and we do another passing going over the first column and making all rows zero.\nat last we use our 2 variables that indicate if our first row or first column had a zero and change those suitably by making them all zero as well.\nhence our problem gets solved. nice i didn't think of that i would remember this pattern of solving for later reference as well.",
      "autoResize": true,
      "lineHeight": 1.25
    },
