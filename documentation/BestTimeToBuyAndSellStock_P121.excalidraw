    {
      "id": "VfkCRKVXJL2U_rX00B7J1",
      "type": "text",
      "x": 6677.983758831564,
      "y": -1900.062642379558,
      "width": 2139.854248046875,
      "height": 310,
      "angle": 0,
      "strokeColor": "#2f9e44",
